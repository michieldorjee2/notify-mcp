{
  "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.19/MicrosoftTeams.schema.json",
  "manifestVersion": "1.19",
  "version": "1.0.0",
  "id": "{{BOT_APP_ID}}",
  "name": {
    "short": "Notify Bot",
    "full": "Notify Bot — MCP Notification Service"
  },
  "description": {
    "short": "Receive notifications from connected tools",
    "full": "Install this bot to receive adaptive card notifications from any MCP-connected tool. On install you'll get a PIN — share it with your tool to start receiving notifications in this conversation."
  },
  "developer": {
    "name": "notify-mcp",
    "websiteUrl": "https://notify-mcp.vercel.app",
    "privacyUrl": "https://notify-mcp.vercel.app",
    "termsOfUseUrl": "https://notify-mcp.vercel.app"
  },
  "icons": {
    "color": "color.png",
    "outline": "outline.png"
  },
  "accentColor": "#0078D4",
  "defaultInstallScope": "personal",
  "defaultGroupCapability": {
    "team": "bot",
    "groupChat": "bot"
  },
  "bots": [
    {
      "botId": "{{BOT_APP_ID}}",
      "scopes": ["personal", "team", "groupChat"],
      "supportsFiles": false,
      "isNotificationOnly": false,
      "commandLists": [
        {
          "scopes": ["personal", "team", "groupChat"],
          "commands": [
            {
              "title": "regenerate",
              "description": "Generate a new PIN for this conversation"
            }
          ]
        }
      ]
    }
  ],
  "validDomains": ["notify-mcp.vercel.app"]
}
